# Copy this file to .env.local and fill in the values. .env.local is gitignored;
# this example is committed so teammates know which variables the app expects.

# Base URL of the running go-mcp-server. The docs pages derive every connection
# URL from this (e.g. ${NEXT_PUBLIC_MCP_BASE_URL}/memory/mcp). Point it at your
# tunnel/prod host when deploying.
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8080

# Neon Postgres connection string — the SAME instance the Go MCP server uses
# (root .env DATABASE_URL). The /api/keys route handlers read+write the api_keys
# table here, so keys minted in the dashboard are immediately valid as the
# X-API-Key header on the MCP endpoints. Server-only; never exposed to the client.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# PostHog product analytics. Publishable client-side key (starts with "phc_")
# from PostHog → Settings → Project → Project API Key. Leave blank to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk URL routing — must match the (auth) route group in src/app/(auth).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After auth, land on the API-keys dashboard (the sign-in/up pages also set this
# via forceRedirectUrl; this is the fallback when the flow starts elsewhere).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/doc/keys
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/doc/keys
