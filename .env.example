# HTTP listen port
PORT=8080

# Postgres with the pgvector extension. Required by the memory namespace; the
# server refuses to start without it. Apply migrations/0001_memories.sql first.
DATABASE_URL=postgres://user:pass@localhost:5432/mcp

# Embeddings for the memory namespace (text-embedding-3-small, 1536 dims).
OPENAI_API_KEY=

# Firecrawl API key for the skills namespace (web scraping/crawling).
FIRECRAWL_API_KEY=

# Model driving the skills_find on-demand skill agent (OpenAI tool-calling loop
# over the Firecrawl tools). Optional; defaults to gpt-4o-mini. Reuses
# OPENAI_API_KEY above — skills_find is disabled when that key is absent.
SKILLS_AGENT_MODEL=

# --- Google Search Console (gsc namespace) ---
# Path to a service-account JSON key with access to your GSC properties. The
# service account must be added as a user on each property (Search Console →
# Settings → Users and permissions), or hold domain-wide delegation. If unset,
# the server falls back to Application Default Credentials
# (GOOGLE_APPLICATION_CREDENTIALS / gcloud / metadata server). The gsc namespace
# mounts either way; tools report the configuration status via gsc_capabilities.
GSC_CREDENTIALS_PATH=

# Default search-analytics data freshness: "all" (default, matches the GSC
# dashboard and includes fresh partial data) or "final" (finalized only, ~2-3
# day lag). Per-call data_state overrides this.
GSC_DATA_STATE=all

# Gate for mutating GSC tools (add/delete site, submit/delete sitemap). Off by
# default so a misconfigured client cannot alter a property. Set to true to enable.
GSC_ALLOW_DESTRUCTIVE=false

# --- Product Hunt (producthunt namespace) ---
# A non-expiring developer token from the Product Hunt API dashboard
# (https://www.producthunt.com/v2/oauth/applications). Simplest option; used
# directly as the bearer token. The producthunt namespace mounts either way;
# tools report the configuration status via producthunt_capabilities.
PRODUCTHUNT_TOKEN=

# Alternative to PRODUCTHUNT_TOKEN: OAuth2 client-credentials. When no developer
# token is set, the server fetches a public-scope token from these and caches it.
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=

# --- Kafka / Confluent Cloud (event namespace) ---
# Confluent Cloud bootstrap host:port (Cluster Settings; comma-separate several).
# Connection is SASL_SSL with mechanism PLAIN. Like skills/gsc (and unlike
# memory), missing config is not a startup failure: the namespace mounts and each
# tool reports the problem; event_capabilities shows the status.
KAFKA_BOOTSTRAP_SERVERS=
# Confluent API key (SASL username) and secret (SASL password).
KAFKA_API_KEY=
KAFKA_API_SECRET=
# Default consumer group for event_consume (group mode).
KAFKA_CONSUMER_GROUP=go-mcp-server
# Optional default topic for event_publish / event_consume.
KAFKA_DEFAULT_TOPIC=
# Gate for topic create/delete (like GSC_ALLOW_DESTRUCTIVE). Off by default.
KAFKA_ALLOW_TOPIC_ADMIN=false

# Auth: every namespace requires a registered X-API-Key header (see
# internal/auth). Keys live in the api_keys table -- mint one rather than
# setting anything here. GET /healthz is the only unauthenticated route.

# --- Clerk (key-management API) ---
# Backend secret for the Clerk instance (Clerk dashboard -> API Keys), the same
# instance the web frontend uses. When set, the server mounts /api/keys: a
# Clerk-authenticated API to list/create/revoke a signed-in user's keys, scoped
# to their Clerk user id and capped per user. The web dashboard calls it with
# the user's Clerk session token. Leave unset to disable that API and mint keys
# only via `make apikey`. The MCP namespaces never use Clerk -- they admit by
# X-API-Key regardless.
CLERK_SECRET_KEY=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Set to "true" when running behind a tunnel or reverse proxy (ngrok, Cloudflare).
# The MCP transport rejects requests that arrive on loopback with a non-loopback
# Host header (DNS-rebinding protection) — which is exactly what a tunnel does.
# Leave unset when serving localhost directly.
MCP_ALLOW_EXTERNAL_HOST=true
