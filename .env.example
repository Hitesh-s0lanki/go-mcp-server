# HTTP listen port
PORT=8080

# Postgres with the pgvector extension. Required by the memory namespace; the
# server refuses to start without it. Apply migrations/0001_memories.sql first.
DATABASE_URL=postgres://user:pass@localhost:5432/mcp

# Embeddings for the memory namespace (text-embedding-3-small, 1536 dims).
OPENAI_API_KEY=

# Firecrawl API key for the skills namespace (web scraping/crawling).
FIRECRAWL_API_KEY=

# Model driving the skills_find on-demand skill agent (OpenAI tool-calling loop
# over the Firecrawl tools). Optional; defaults to gpt-4o-mini. Reuses
# OPENAI_API_KEY above — skills_find is disabled when that key is absent.
SKILLS_AGENT_MODEL=

# Optional GitHub token for skills_download. Public repos work without it; a
# token raises GitHub's 60/hr unauthenticated rate limit for the contents API.
GITHUB_TOKEN=

# Bearer token for the auth middleware (leave blank to disable in dev)
AUTH_TOKEN=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Set to "true" when running behind a tunnel or reverse proxy (ngrok, Cloudflare).
# The MCP transport rejects requests that arrive on loopback with a non-loopback
# Host header (DNS-rebinding protection) — which is exactly what a tunnel does.
# Leave unset when serving localhost directly.
MCP_ALLOW_EXTERNAL_HOST=true
